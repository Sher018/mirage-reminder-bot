# Скопируйте в .env и заполните значения
# На сервере задайте эти переменные в панели (не создавайте .env)

# Токен бота (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# ID администраторов через запятую (узнать: @userinfobot)
ADMIN_IDS=123456789

# ID группы (узнать: /groupid в группе). Или выполните /setgroup в группе
GROUP_ID=-1001234567890

# На Amvera/сервере — обязательно для сохранения данных
DATABASE_PATH=/data/bot.db

# Координаты ресторана (опционально)
RESTAURANT_LAT=52.2758
RESTAURANT_LON=104.2774
GEO_RADIUS_M=200

# Окно подтверждения (минуты)
CONFIRM_WINDOW_MINUTES=15
LATE_REMINDER_MINUTES=7

# Недельный отчёт: воскресенье 00:00
WEEKLY_REPORT_DAY=0
WEEKLY_REPORT_TIME=00:00

# Часовой пояс (сервер в UTC). Asia/Irkutsk = Иркутск UTC+8
TIMEZONE=Asia/Irkutsk
